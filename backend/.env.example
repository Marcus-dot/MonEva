SECRET_KEY=your-secret-key-here
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# CORS — set to False in production and list your frontend URLs
CORS_ALLOW_ALL_ORIGINS=True
CORS_ALLOWED_ORIGINS=http://localhost:3000
# Must be True when using credentials: 'include' (cookie auth)
CORS_ALLOW_CREDENTIALS=True

# Email (Gmail SMTP example)
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=your-email@gmail.com
EMAIL_HOST_PASSWORD=your-app-password
DEFAULT_FROM_EMAIL=noreply@moneva.kgl.co.zm

# Finance
# ZMW exchange rate (how many ZMW per 1 USD)
USD_TO_ZMW_RATE=27

# Grievance rate limiting (set to False to disable for internal deployments)
GRIEVANCE_RATE_LIMIT_ENABLED=True

# Logging
DJANGO_LOG_LEVEL=WARNING
